   stun_only: false,\n45:fd2|        stun_port: 31232,\n46:4e2|        quic: None,\n47:7c3|    }])\n48:d08|    .unwrap();\n49:4d2|    let pkarr_publisher =\n50:d99|        PkarrPublisher::new(node_secret_key.as_ref().clone(), pkarr_url.parse().unwrap());\n51:d05|\n52:e3d|    // #[cfg(target_arch = \"wasm32\")]\n53:a2b|    let discovery2 = iroh::discovery::pkarr::PkarrResolver::new(pkarr_url.parse().unwrap());\n54:3e1|    // #[cfg(not(target_arch = \"wasm32\"))]\n55:8cd|    // let discovery2 = iroh::discovery::dns::DnsDiscovery::new(\n56:59a|    //     \"127.0.0.1\".parse().unwrap()\n57:6a6|    // );\n58:d05|\n59:9ca|    Endpoint::builder()\n60:5a7|        .secret_key(node_secret_key.as_ref().clone())\n61:c17|        // .discovery_n0()\n62:86a|        .relay_mode(iroh::RelayMode::Custom(relay_map))\n63:373|        .add_discovery(|_| Some(pkarr_publisher))\n64:e46|        .add_discovery(|_| Some(discovery2))\n65:b16|        .alpns(vec![\n66:660|            Echo::ALPN.to_vec(),\n67:01c|            GOSSIP_ALPN.to_vec(),\n68:fbe|            // DIRECT_MESSAGE_ALPN.to_vec(),\n69:b3c|        ])\n70:7b8|        .bind()\n71:dcc|        .await\n72:b18|}\n73:d05|\n74:fff|impl MainNode {\n75:852|    pub async fn spawn(\n76:309|        node_identity: Arc<NodeIdentity>,\n77:fd6|        node_secret_key: Arc<SecretKey>,\n78:44e|        own_endpoint_node_id: Option<NodeId>,\n79:da2|        user_secrets: Arc<UserIdentitySecrets>,\n80:7a8|        sleep_manager: SleepManager,\n81:e6e|    ) -> Result<Self> {\n82:042|        assert!(node_secret_key.public() == *node_identity.node_id());\n83:ac4|        assert!(node_identity.user_id() == user_secrets.user_identity().user_id());\n84:274|        assert!(*node_identity.user_id() == user_secrets.secret_key().public());\n85:d36|        let message_signer = MessageSigner {\n86:cf7|            node_secret_key: node_secret_key.clone(),\n87:183|            user_secrets: user_secrets.clone(),\n88:bd0|            node_identity: node_identity.clone(),