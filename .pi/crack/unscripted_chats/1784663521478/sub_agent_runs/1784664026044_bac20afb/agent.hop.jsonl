ers"},{"line":498,"hash":"31c","anchor":"498:31c","raw":"        // or receivers are still around. Keep controllers for the room's life!","display":"        // or receivers are still around. Keep controllers for the room's life!"},{"line":499,"hash":"d56","anchor":"499:d56","raw":"        drop(controller);","display":"        drop(controller);"},{"line":500,"hash":"b18","anchor":"500:b18","raw":"    }","display":"    }"},{"line":501,"hash":"d05","anchor":"501:d05","raw":"","display":""},{"line":502,"hash":"483","anchor":"502:483","raw":"    #[tokio::test]","display":"    #[tokio::test]"},{"line":503,"hash":"e16","anchor":"503:e16","raw":"    async fn regression_join_peers_reaches_room() {","display":"    async fn regression_join_peers_reaches_room() {"},{"line":504,"hash":"b00","anchor":"504:b00","raw":"        let (controller, raw) = make_controller();","display":"        let (controller, raw) = make_controller();"},{"line":505,"hash":"794","anchor":"505:794","raw":"        let sender = controller.sender();","display":"        let sender = controller.sender();"},{"line":506,"hash":"cac","anchor":"506:cac","raw":"        let peer = iroh::SecretKey::generate(rand::thread_rng()).public();","display":"        let peer = iroh::SecretKey::generate(rand::thread_rng()).public();"},{"line":507,"hash":"d28","anchor":"507:d28","raw":"        sender","display":"        sender"},{"line":508,"hash":"516","anchor":"508:516","raw":"            .join_peers(vec![peer])","display":"            .join_peers(vec![peer])"},{"line":509,"hash":"dcc","anchor":"509:dcc","raw":"            .await","display":"            .await"},{"line":510,"hash":"2c1","anchor":"510:2c1","raw":"            .expect(\"join_peers should reach the raw room\");","display":"            .expect(\"join_peers should reach the raw room\");"},{"line":511,"hash":"896","anchor":"511:896","raw":"        assert_eq!(raw.joined_peers.lock().unwrap().as_slice(), &[peer]);","display":"        assert_eq!(raw.joined_peers.lock()