       let mut bootstrap = ticket.bootstrap.clone();\n39:0a0|        bootstrap.remove(&node.node_id());\n40:23d|        let bootstrap = bootstrap.into_iter().collect::<Vec<_>>();\n41:b82|        let have_bootstrap = !bootstrap.is_empty();\n42:098|        let mut gossip_topic = node.gossip.subscribe(ticket.topic_id, bootstrap)?;\n43:2d3|        if have_bootstrap {\n44:6ca|            let _ = n0_future::time::timeout(CONNECT_TIMEOUT, gossip_topic.joined()).await;\n45:b18|        }\n46:c0d|        let (gossip_send, gossip_recv) = gossip_topic.split();\n47:948|        let gossip_send = Arc::new(RwLock::new(Some(gossip_send)));\n48:042|        let (msg_send, msg_recv) = tokio::sync::mpsc::channel::<Arc<Vec<u8>>>(2048);\n49:10a|        let room = Self {\n50:aeb|            own_node_id: node.node_id(),\n51:2af|            direct_message: node.chat_direct_message.clone(),\n52:9dd|            topic_id: ticket.topic_id,\n53:9e3|            gossip_send,\n54:fe0|            task: Arc::new(RwLock::new(None)),\n55:c73|            msg_recv: Arc::new(RwLock::new(Some(msg_recv))),\n56:aa9|        };\n57:1fc|        {\n58:051|            let task = Some(AbortOnDropHandle::new(spawn(async move {\n59:803|                let _r = task_loop(room.topic_id, gossip_recv, direct_message_recv, msg_send).await;\n60:944|                warn!(\"ZZZ: chat room task loop closed: {:?}\", _r);\n61:59b|            })));\n62:cbe|            *room.task.write().await = task;\n63:b18|        }\n64:757|        Ok(room)\n65:b18|    }\n66:b18|}\n67:d05|\n68:4ff|async fn task_loop(\n69:a20|    topic_id: TopicId,\n70:d1a|    mut gossip_recv: GossipReceiver,\n71:c4b|    mut direct_message_recv: async_broadcast::Receiver<(PublicKey, ChatDirectMessage)>,\n72:d48|    msg_send: tokio::sync::mpsc::Sender<Arc<Vec<u8>>>,\n73:d1d|) -> Result<()> {\n74:4b3|    loop {\n75:e78|        tokio::select! {\n76:069|            msg = gossip_recv.next().fuse() => {\n77:59c|                let Some(msg) = msg else {\n78:a42|     