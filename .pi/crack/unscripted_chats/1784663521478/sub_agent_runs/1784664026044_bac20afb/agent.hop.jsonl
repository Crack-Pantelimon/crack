y, UserIdentitySecrets},\n25:aa9|};\n26:d05|\n27:f8f|/// Main P2P node wrapper combining router, gossip, direct messaging, and chat.\n28:982|#[derive(Debug, Clone)]\n29:81c|pub struct MainNode {\n30:702|    pub(crate) router: Router,\n31:ffb|    pub(crate) gossip: Gossip,\n32:231|    pub(crate) node_identity: Arc<NodeIdentity>,\n33:863|    pub(crate) sleep_manager: SleepManager,\n34:3a1|    pub(crate) message_signer: MessageSigner,\n35:79b|    pub(crate) direct_message_recv:\n36:462|        async_broadcast::InactiveReceiver<(PublicKey, ChatDirectMessage)>,\n37:383|    pub(crate) chat_direct_message: DirectMessageProtocol<ChatDirectMessage>,\n38:b18|}\n39:d05|\n40:ea5|async fn create_endpoint(node_secret_key: Arc<SecretKey>) -> anyhow::Result<Endpoint> {\n41:d12|    let (relay_url, pkarr_url) = get_relay_domain();\n42:281|    let relay_map = RelayMap::from_nodes([RelayNode {\n43:768|        url: relay_url.parse().unwrap(),\n44:e38|        stun_only: false,\n45:fd2|        stun_port: 31232,\n46:4e2|        quic: None,\n47:7c3|    }])\n48:d08|    .unwrap();\n49:4d2|    let pkarr_publisher =\n50:d99|        PkarrPublisher::new(node_secret_key.as_ref().clone(), pkarr_url.parse().unwrap());\n51:d05|\n52:e3d|    // #[cfg(target_arch = \"wasm32\")]\n53:a2b|    let discovery2 = iroh::discovery::pkarr::PkarrResolver::new(pkarr_url.parse().unwrap());\n54:3e1|    // #[cfg(not(target_arch = \"wasm32\"))]\n55:8cd|    // let discovery2 = iroh::discovery::dns::DnsDiscovery::new(\n56:59a|    //     \"127.0.0.1\".parse().unwrap()\n57:6a6|    // );\n58:d05|\n59:9ca|    Endpoint::builder()\n60:5a7|        .secret_key(node_secret_key.as_ref().clone())\n61:c17|        // .discovery_n0()\n62:86a|        .relay_mode(iroh::RelayMode::Custom(relay_map))\n63:373|        .add_discovery(|_| Some(pkarr_publisher))\n64:e46|        .add_discovery(|_| Some(discovery2))\n65:b16|        .alpns(vec![\n66:660|            Echo::ALPN.to_vec(),\n67:01c|            GOSSIP_ALPN.to_vec(),\n68:fbe|           