            inner: inner.clone(),\n96:b17|            message_signer: message_signer.clone(),\n97:b25|            current_presence: Arc::new(RwLock::new(None)),\n98:bcc|            chatroom_presence: presence.clone(),\n99:155|            _p: PhantomData,\n100:aa9|        };\n101:ac1|        let (mut msg_sender, mut msg_receiver) = async_broadcast::broadcast(16);\n102:4f9|        msg_sender.set_overflow(true);\n103:146|        msg_receiver.set_overflow(true);\n104:d05|\n105:555|        let msg_receiver = Arc::new(RwLock::new(msg_receiver));\n106:5ec|        let receiver = ChatReceiver {\n107:666|            msg_receiver,\n108:155|            _p: PhantomData,\n109:aa9|        };\n110:c84|        let inner2 = inner.clone();\n111:336|        let _presence = presence.clone();\n112:bc7|        let _sender = sender.clone();\n113:984|        let _sleep_manager = sleep_manager.clone();\n114:70a|        let _dispatch_task = async move {\n115:997|            let mut errors = 0;\n116:4b3|            loop {\n117:a36|                let Ok(Some(message)) = inner2.next_message().await else {\n118:9ff|                    errors += 1;\n119:fd3|                    if errors > 10 {\n120:965|                        warn!(\"_dispatch_task: Chat room closed\");\n121:7ed|                        anyhow::bail!(\"_dispatch_task: Chat room closed\");\n122:b18|                    }\n123:9a1|                    _sleep_manager\n124:cf5|                        .sleep(std::time::Duration::from_millis(8))\n125:d19|                        .await;\n126:848|                    continue;\n127:aa9|                };\n128:2ca|                errors = 0;\n129:cc5|                let msg = SignedMessage::verify_and_decode::<ChatMessage<T>>(&message);\n130:607|                match msg {\n131:3cf|                    Ok(m) => {\n132:bca|                        if let Err(e) = _dispatch_inner_loop::<T>(\n133:b4f|                            m,\n134:566|                            &mut msg_sender,\n135:963|    