8a|//!   [`NetworkManager::join_room`].\n7:161|//! - Headless workers call [`run_standalone_bootstrap_if_needed`] to spawn a\n8:1c4|//!   bootstrap node when none is reachable.\n9:0bd|//!\n10:7b5|//! This module is parametric over room types: game-specific message types\n11:14a|//! live in the game's own crates. Bootstrap nodes subscribe to the extra\n12:c56|//! topics listed in [`NetworkManagerConfig::bootstrap_topics`] at the *raw*\n13:6c5|//! gossip layer only — they never decode the traffic, they just have to be\n14:656|//! subscribed, because iroh-gossip can only bootstrap a topic swarm through\n15:22c|//! peers that are themselves subscribed to that topic.\n16:d05|\n17:00a|use std::{sync::Arc, time::Duration};\n18:d05|\n19:f3c|use anyhow::{Context, Result};\n20:0d1|use iroh::{Endpoint, NodeId, RelayMap, RelayNode, SecretKey};\n21:133|use n0_future::task::AbortOnDropHandle;\n22:aec|use tokio::sync::RwLock;\n23:c5b|use tracing::{info, warn};\n24:d05|\n25:a91|use crate::{\n26:68d|    _bootstrap_keys::BOOTSTRAP_SECRET_KEYS,\n27:60f|    chat::{\n28:245|        chat_const::{get_relay_domain, GLOBAL_CHAT_TOPIC_ID},\n29:501|        chat_controller::{ChatController, IChatController, IChatRoomRaw, IChatSender},\n30:26d|        chat_ticket::ChatTicket,\n31:586|        global_chat::{GlobalChatPresence, GlobalChatRoomType},\n32:4eb|        room_raw::GossipChatRoom,\n33:2f6|    },\n34:142|    echo::Echo,\n35:40b|    global_matchmaker::GlobalMatchmaker,\n36:65f|    main_node::MainNode,\n37:a47|    signed_message::IChatRoomType,\n38:03e|    sleep::SleepManager,\n39:fc9|    user_identity::{NodeIdentity, UserIdentitySecrets},\n40:aa9|};\n41:d05|\n42:9a7|/// Configuration for the global network init.\n43:b09|#[derive(Debug, Clone, Default)]\n44:526|pub struct NetworkManagerConfig {\n45:991|    /// Extra gossip topics (besides the global chat) that every bootstrap\n46:0dd|    /// node subscribes to, raw. All traffic on them is dropped (a drop\n47:a09|    /// counter is logged every 10 minutes). Bootstrap nodes subscribe only so\n48:8ab|    /// that clients always find a live, already-subscribed peer to bootstrap\n49:255|    /// the topic's gossip swarm from — otherwise two clients joining a topic\n50:e4e|    /// at the same time would each sit alone in their own swarm.\n51:7f5|    pub bootstrap_topics: Vec<String>,\n52:b18|}\n53:d05|\n54:9d0|/// Single \"network manager\" object containing all running network code:\n55:9fc|/// the matchmaker (own node, optional bootstrap endpoint, global chats,\n56:0f3|/// periodic maintenance) plus the per-room peer-join tasks spawned by\n57:41f|/// [`NetworkManager::join_room`].\n58:982|#[derive(Debug, Clone)]\n59:aca|pub struct NetworkManager {\n60:ce0|    mm: GlobalMatchmaker,\n61:3ae|    tasks: Arc<RwLock<Vec<AbortOnDropHandle<()>>>>,\n62:b18|}\n63:d05|\n64:624|impl NetworkManager {\n65:8d1|    /// Global network init. Creates the matchmaker: spawns the own node,\n66:596|    /// takes over a free bootstrap slot if needed (the bootstrap node then\n67:201|    /// joins the global chat *and* every topic in\n68:cbf|    /// [`NetworkManagerConfig::bootstrap_topics`]), joins the global chat,\n69:c88|    /// and starts the periodic maintenance task.\n70:d89|    pub async fn init(\n71:38e|        secrets: Arc<UserIdentitySecrets>,\n72:676|        config: NetworkManagerConfig,\n73:e6e|    ) -> Result<Self> {\n74:33a|        let mm = GlobalMatchmaker::new_with_config(secrets, config).await?;\n75:935|        Ok(Self {\n76:013|            mm,\n77:1ad|            tasks: Arc::new(RwLock::new(Vec::new())),\n78:417|        })\n79:b18|    }\n80:d05|\n81:822|    pub fn matchmaker(&self) -> GlobalMatchmaker {\n82:43a|        self.mm.clone()\n83:b18|    }\n84:d05|\n85:a36|    pub async fn global_chat_controller(&self) -> Option<ChatController<GlobalChatRoomType>> {\n86:6f8|        self.mm.global_chat_controller().await\n87:b18|    }\n88:d05|\n89:63e|    /// Join a gossip room on the own node. The ticket lists every known\n90:8ad|    /// bootstrap node id *and* the node ids owning them, so two clients\n91:490|    /// joining the same topic at the same time still meet through the\n92:336|    /// bootstrap swarm.\n93:611|    ///\n94:195|    /// Also spawns a presence-driven `join_peers` refresher: whenever the\n95:462|    /// room's presence list changes, a direct gossip connection to every\n96:777|    /// present peer (and every known bootstrap node) is forced/refreshed.\n97:64c|    /// Without this, high-rate broadcasts get relayed through the bootstrap\n98:b38|    /// mesh, which drops peers under load.\n99:b51|    pub async fn join_room<T: IChatRoomType>(&self, topic_id: &str) -> Result<ChatController<T>> {\n100:5a8|        let node = self.mm.own_node().await.context(\"join_room: no node\")?;\n101:afd|        let ticket = ChatTicket::new_str_bs(topic_id, self.mm.bootstrap_nodes_set().await);\n102:9e2|        let controller = node.join_chat::<T>(&ticket).await?;\n103:d05|\n104:e03|        let presence = controller.chat_presence();\n105:794|        let sender = controller.sender();\n106:7d4|        let own_node_id = *self.mm.own_node_identity().node_id();\n107:0bc|        let mm = self.mm.clone();\n108:8c5|        let topic = topic_id.to_string();\n109:698|        let task = AbortOnDropHandle::new(n0_future::task::spawn(async move {\n110:4b3|            loop {\n111:75e|                presence.notified().await;\n112:564|                let list = presence.get_presence_list().await;\n113:4d6|                let mut peers = mm.bootstrap_nodes_set().await;\n114:368|                peers.extend(list.0.iter().map(|p| *p.identity.node_id()));\n115:50f|                peers.remove(&own_node_id);\n116:797|                let peers: Vec<NodeId> = peers.into_iter().collect();\n117:669|                if !peers.is_empty() {\n118:f62|                    if let Err(e) = sender.join_peers(peers).await {\n119:848|                        warn!(\"room '{topic}': presence join_peers failed: {e:?}\");\n120:b18|                    }\n121:b18|                }\n122:b18|            }\n123:554|        }));\n124:f7a|        self.tasks.write().await.push(task);\n125:d05|\n126:910|        Ok(controller)\n127:b18|    }\n128:d05|\n129:591|    pub async fn shutdown(&self) -> Result<()> {\n130:1af|        self.tasks.write().await.clear();\n131:a69|        self.mm.shutdown().await\n132:b18|    }\n133:b18|}\n134:d05|\n135:9aa|/// Drain a raw gossip room forever, dropping every message. Keeps a drop\n136:617|/// counter and logs it every 10 minutes.\n137:577|pub(crate) fn spawn_topic_drain_task(\n138:faf|    room: Arc<dyn IChatRoomRaw>,\n139:a80|    label: String,\n140:9c3|) -> AbortOnDropHandle<()> {\n141:13c|    AbortOnDropHandle::new(n0_future::task::spawn(async move {\n142:21b|        const LOG_INTERVAL: Duration = Duration::from_secs(600);\n143:678|        let mut total_msgs: u64 = 0;\n144:344|        let mut total_bytes: u64 = 0;\n145:783|        let mut window_msgs: u64 = 0;\n146:319|        let mut window_bytes: u64 = 0;\n147:015|        let mut last_log = n0_future::time::Instant::now();\n148:4b3|        loop {\n149:931|            // Timeout so the 10-minute stat line is printed even if the room\n150:07a|            // goes idle.\n151:a35|            match n0_future::time::timeout(Duration::from_secs(60), room.next_message()).await {\n152:4da|                Ok(Ok(Some(msg))) => {\n153:d90|                    window_msgs += 1;\n154:2b6|                    window_bytes += msg.len() as u64;\n155:b18|                }\n156:67b|                Ok(Ok(None)) | Ok(Err(_)) => {\n157:f4c|                    warn!(\"{label}: drain task exiting: room closed\");\n158:81d|                    break;\n159:b18|                }\n160:b53|                Err(_timeout) => {}\n161:b18|            }\n162:019|            if last_log.elapsed() >= LOG_INTERVAL {\n163:a73|                total_msgs += window_msgs;\n164:0ab|                total_bytes += window_bytes;\n165:259|                info!(\n166:25d|                    \"{label}: dropped {window_msgs} msgs ({window_bytes} B) in the last 10 min \\\n167:7d7|                     (total: {total_msgs} msgs, {total_bytes} B)\"\n168:82c|                );\n169:675|                window_msgs = 0;\n170:5e7|                window_bytes = 0;\n171:2d3|                last_log = n0_future::time::Instant::now();\n172:b18|            }\n173:b18|        }\n174:b9b|    }))\n175:b18|}\n176:d05|\n177:4ff|/// Probe the well-known bootstrap node ids over the Echo ALPN.\n178:994|async fn any_bootstrap_alive() -> Result<bool> {\n179:d12|    let (relay_url, pkarr_url) = get_relay_domain();\n180:281|    let relay_map = RelayMap::from_nodes([RelayNode {\n181:768|        url: relay_url.parse().unwrap(),\n182:e38|        stun_only: false,\n183:fd2|        stun_port: 31232,\n184:4e2|        quic: None,\n185:7c3|    }])\n186:d08|    .unwrap();\n187:6ea|    let pkarr_resolver = iroh::discovery::pkarr::PkarrResolver::new(pkarr_url.parse().unwrap());\n188:d05|\n189:bd3|    let temp_key = SecretKey::generate(rand::thread_rng());\n190:5d5|    let endpoint = Endpoint::builder()\n191:4eb|        .secret_key(temp_key)\n192:86a|        .relay_mode(iroh::RelayMode::Custom(relay_map))\n193:24e|        .add_discovery(move |_| Some(pkarr_resolver.clone()))\n194:7b8|        .bind()\n195:0c3|        .await?;\n196:d05|\n197:d51|    for bs_known_secret in BOOTSTRAP_SECRET_KEYS.iter() {\n198:0e4|        let bs_node_id = SecretKey::from_bytes(bs_known_secret).public();\n199:f02|        info!(\"Checking bootstrap node: {:?}\", bs_node_id);\n200:d05|\n201:3a8|        let conn_res = n0_future::time::timeout(\n202:416|            Duration::from_millis(1500),\n203:afc|            endpoint.connect(bs_node_id, Echo::ALPN),\n204:f8e|        )\n205:d19|        .await;\n206:d05|\n207:f3e|        if let Ok(Ok(_conn)) = conn_res {\n208:6ce|            info!(\"Found live bootstrap node: {:?}\", bs_node_id);\n209:705|            return Ok(true);\n210:b18|        }\n211:b18|    }\n212:3bf|    Ok(false)\n213:b18|}\n214:d05|\n215:b0e|/// If no bootstrap node is reachable, spawn one locally on the well-known\n216:0a2|/// key #0 and connect it to the correct networks: the global chat (typed,\n217:626|/// with a \"Bootstrap\" presence, answering bootstrap queries) and every topic\n218:549|/// in `extra_topics` (raw, all traffic dropped and counted). Never returns\n219:d3a|/// in that case. Called from the headless workers.\n220:c4e|pub async fn run_standalone_bootstrap_if_needed(extra_topics: Vec<String>) -> Result<()> {\n221:ce5|    if any_bootstrap_alive().await? {\n222:ba9|        info!(\"At least one bootstrap node is alive. No action needed.\");\n223:58c|        return Ok(());\n224:b18|    }\n225:79e|    info!(\"No live bootstrap nodes found. Spawning local bootstrap node index 0...\");\n226:d05|\n227:312|    let bootstrap_idx = 0;\n228:b12|    let bootstrap_key = SecretKey::from_bytes(&BOOTSTRAP_SECRET_KEYS[bootstrap_idx]);\n229:d05|\n230:65c|    let user_secrets = Arc::new(UserIdentitySecrets::generate());\n231:d90|    let node_identity = Arc::new(NodeIdentity::new(\n232:099|        *user_secrets.user_identity(),\n233:58f|        bootstrap_key.public(),\n234:423|        Some(bootstrap_idx as u32),\n235:10a|    ));\n236:d05|\n237:769|    let bootstrap_node = MainNode::spawn(\n238:fb9|        node_identity,\n239:668|        Arc::new(bootstrap_key),\n240:543|        None,\n241:b25|        user_secrets,\n242:222|        SleepManager::new(),\n243:f8e|    )\n244:0c3|    .await?;\n245:d05|\n246:259|    info!(\n247:e5a|        \"Bootstrap node successfully spawned! Node ID: {:?}\",\n248:e25|        bootstrap_node.node_id()\n249:82c|    );\n250:d05|\n251:fc4|    // All other well-known bootstrap ids, as the ticket bootstrap set.\n252:491|    let bs_set = BOOTSTRAP_SECRET_KEYS\n253:17c|        .iter()\n254:909|        .map(|k| SecretKey::from_bytes(k).public())\n255:566|        .collect::<std::collections::BTreeSet<_>>();\n256:d05|\n257:07d|    // Global chat: typed join, so the node shows up as \"Bootstrap\" presence\n258:29d|    // and answers server-list bootstrap queries like matchmaker-owned\n259:492|    // bootstrap nodes do.\n260:7ed|    let global_ticket = ChatTicket::new_str_bs(GLOBAL_CHAT_TOPIC_ID, bs_set.clone());\n261:00b|    let _global_chat: Option<(ChatController<GlobalChatRoomType>, AbortOnDropHandle<()>)> =\n262:211|        match bootstrap_node\n263:5ce|            .join_chat::<GlobalChatRoomType>(&global_ticket)\n264:dcc|            .await\n265:1fc|        {\n266:b5f|            Ok(cc) => {\n267:959|                cc.sender()\n268:ad9|                    .set_presence(&GlobalChatPresence {\n269:13f|                        url: \"\".to_string(),\n270:44f|                        platform: \"Bootstrap\".to_string(),\n271:e2b|                        is_server: None,\n272:417|                    })\n273:d19|                    .await;\n274:5ba|                let cc2 = cc.clone();\n275:698|                let task = AbortOnDropHandle::new(n0_future::task::spawn(async move {\n276:0ea|                    if let Err(e) = crate::global_matchmaker::run_bs_global_chat_task(cc2).await {\n277:1ab|                        warn!(\"standalone bootstrap global chat task exited: {e:?}\");\n278:b18|                    }\n279:554|                }));\n280:07e|                Some((cc, task))\n281:b18|            }\n282:ba5|            Err(e) => {\n283:71c|                warn!(\"standalone bootstrap failed to join global chat: {e:?}\");\n284:ddc|                None\n285:b18|            }\n286:aa9|        };\n287:d05|\n288:e6d|    // Extra topics (e.g. the gameplay room): raw subscribe + drop all traffic.\n289:692|    let mut _drain_tasks = Vec::new();\n290:d0e|    for topic in &extra_topics {\n291:050|        let ticket = ChatTicket::new_str_bs(topic, bs_set.clone());\n292:4c4|        match GossipChatRoom::new(&bootstrap_node, &ticket).await {\n293:58d|            Ok(room) => {\n294:255|                info!(\"standalone bootstrap joined extra gossip topic '{topic}'\");\n295:584|                _drain_tasks.push(spawn_topic_drain_task(\n296:174|                    Arc::new(room),\n297:e2f|                    format!(\"standalone bootstrap, topic '{topic}'\"),\n298:10a|                ));\n299:b18|            }\n300:ba5|            Err(e) => {\n301:1b9|                warn!(\"standalone bootstrap failed to join extra topic '{topic}': {e:?}\");\n302:b18|            }\n303:b18|        }\n304:b18|    }\n305:d05|\n306:6d2|    // Keep the bootstrap node (and its room tasks) alive in the background.\n307:4b3|    loop {\n308:074|        n0_future::time::sleep(Duration::from_secs(3600)).await;\n309:b18|    }\n310:b18|}"}],"details":{"readSeekValue":{"tool":"read","path":"/workspace/rust_pkg/net_crackpipe/src/network_manager.rs","range":{"startLine":1,"endLine":310,"totalLines":310},"warnings":[],"truncation":null,"symbol":null,"map":{"requested":false,"appended":false},"lines":[{"line":1,"hash":"315","anchor":"1:315","raw":"//! Global network init: one entry point that owns all running network code.","display":"//! Global network init: one entry point that owns all running network code."},{"line":2,"hash":"0bd","anchor":"2:0bd","raw":"//!","display":"//!"},{"line":3,"hash":"d8b","anchor":"3:d8b","raw":"//! - Apps (game, chat_cli) call [`NetworkManager::init`] and get a single","display":"//! - Apps (game, chat_cli) call [`NetworkManager::init`] and get a single"},{"line":4,"hash":"580","anchor":"4:580","raw":"//!   object holding the matchmaker (own node + bootstrap endpoint + global","display":"//!   object holding the matchmaker (own node + bootstrap endpoint + global"},{"line":5,"hash":"4dc","anchor":"5:4dc","raw":"//!   chats + periodic maintenance) and any rooms joined via","display":"//!   chats + periodic maintenance) and any rooms joined via"},{"line":6,"hash":"d8a","anchor":"6:d8a","raw":"//!   [`NetworkManager::join_room`].","display":"//!   [`Ne