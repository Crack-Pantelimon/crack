es::FutureExt;\n5:682|use iroh::NodeId;\n6:9cf|use n0_future::task::{spawn, AbortOnDropHandle};\n7:aec|use tokio::sync::RwLock;\n8:b91|use tokio_stream::StreamExt;\n9:c5b|use tracing::{info, warn};\n10:d05|\n11:a91|use crate::{\n12:510|    chat::chat_const::{CONNECT_TIMEOUT, PRESENCE_INTERVAL},\n13:484|    chat::chat_presence::ChatPresence,\n14:bd8|    chat::chat_ticket::ChatTicket,\n15:82a|    datetime_now,\n16:2c3|    signed_message::{IChatRoomType, MessageSigner, SignedMessage},\n17:03e|    sleep::SleepManager,\n18:ed0|    user_identity::NodeIdentity,\n19:8be|    ReceivedMessage,\n20:aa9|};\n21:d05|\n22:d8f|/// Chat controller for a chat room type.\n23:d5b|/// Manages message dispatch, presence, sender/receiver, and background tasks.\n24:091|#[derive(Clone, Debug)]\n25:fe0|pub struct ChatController<T: IChatRoomType> {\n26:c82|    ticket: ChatTicket,\n27:dd5|    inner: Arc<dyn IChatRoomRaw>,\n28:1fb|    presence: ChatPresence<T>,\n29:c14|    _p: PhantomData<T>,\n30:cf8|    _dispatch_task: Arc<AbortOnDropHandle<anyhow::Result<()>>>,\n31:c1f|    _presence_task: Arc<AbortOnDropHandle<anyhow::Result<()>>>,\n32:c68|    sender: ChatSender<T>,\n33:8bf|    receiver: ChatReceiver<T>,\n34:cc7|    _controller_id: uuid::Uuid,\n35:541|    node_identity: NodeIdentity,\n36:b18|}\n37:d05|\n38:e4b|impl<T: IChatRoomType> PartialEq for ChatController<T> {\n39:1db|    fn eq(&self, other: &Self) -> bool {\n40:475|        self._controller_id == other._controller_id\n41:b18|    }\n42:b18|}\n43:d05|\n44:7e1|async fn _dispatch_inner_loop<T: IChatRoomType>(\n45:ac4|    m: crate::WireMessage<ChatMessage<T>>,\n46:6a6|    msg_sender: &mut async_broadcast::Sender<ReceivedMessage<T>>,\n47:4ae|    _presence: ChatPresence<T>,\n48:750|    _sender: ChatSender<T>,\n49:d17|) -> anyhow::Result<()> {\n50:12c|    match m.message {\n51:0e8|        ChatMessage::Message(message) => {\n52:46d|            msg_sender\n53:be0|                .broadcast(ReceivedMessage {\n54:1b5|                    _sender_time