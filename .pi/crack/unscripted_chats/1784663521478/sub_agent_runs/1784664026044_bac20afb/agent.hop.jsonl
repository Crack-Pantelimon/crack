 };\n101:ac1|        let (mut msg_sender, mut msg_receiver) = async_broadcast::broadcast(16);\n102:4f9|        msg_sender.set_overflow(true);\n103:146|        msg_receiver.set_overflow(true);\n104:d05|\n105:555|        let msg_receiver = Arc::new(RwLock::new(msg_receiver));\n106:5ec|        let receiver = ChatReceiver {\n107:666|            msg_receiver,\n108:155|            _p: PhantomData,\n109:aa9|        };\n110:c84|        let inner2 = inner.clone();\n111:336|        let _presence = presence.clone();\n112:bc7|        let _sender = sender.clone();\n113:984|        let _sleep_manager = sleep_manager.clone();\n114:70a|        let _dispatch_task = async move {\n115:997|            let mut errors = 0;\n116:4b3|            loop {\n117:a36|                let Ok(Some(message)) = inner2.next_message().await else {\n118:9ff|                    errors += 1;\n119:fd3|                    if errors > 10 {\n120:965|                        warn!(\"_dispatch_task: Chat room closed\");\n121:7ed|                        anyhow::bail!(\"_dispatch_task: Chat room closed\");\n122:b18|                    }\n123:9a1|                    _sleep_manager\n124:cf5|                        .sleep(std::time::Duration::from_millis(8))\n125:d19|                        .await;\n126:848|                    continue;\n127:aa9|                };\n128:2ca|                errors = 0;\n129:cc5|                let msg = SignedMessage::verify_and_decode::<ChatMessage<T>>(&message);\n130:607|                match msg {\n131:3cf|                    Ok(m) => {\n132:bca|                        if let Err(e) = _dispatch_inner_loop::<T>(\n133:b4f|                            m,\n134:566|                            &mut msg_sender,\n135:963|                            _presence.clone(),\n136:22f|                            _sender.clone(),\n137:f8e|                        )\n138:dcc|                        .await\n139:1fc|                        {\n140:7ed|                            warn!(\"_dispatch_task: Error dispatching message: {:?}\", e);\n141:b18|                        }\n142:b18|                    }\n143:ba5|                    Err(e) => {\n144:9c6|                        warn!(\"_dispatch_task: Error verifying message: {:?}\", e);\n145:b18|                    }\n146:b18|                }\n147:b18|            }\n148:aa9|        };\n149:767|        let _dispatch_task = AbortOnDropHandle::new(spawn(async move {\n150:6d6|            let r = _dispatch_task.await;\n151:3ed|            warn!(\"_dispatch_task: Chat room closed: {r:#?}\");\n152:b4d|            r\n153:554|        }));\n154:d05|\n155:984|        let _sleep_manager = sleep_manager.clone();\n156:bc7|        let _sender = sender.clone();\n157:cea|        let _presence_task = async move {\n158:4b3|            loop {\n159:359|                let _ = _sleep_manager.sleep(PRESENCE_INTERVAL).await;\n160:580|                if let Err(e) = _sender.broadcast_presence().await {\n161:6cc|                    warn!(\"_presence_task: Error broadcasting presence: {:?}\", e);\n162:285|                    anyhow::bail!(\"_presence_task: Error broadcasting presence: {:?}\", e);\n163:b18|                }\n164:b18|            }\n165:aa9|        };\n166:225|        let _presence_task = AbortOnDropHandle::new(spawn(async move {\n167:6c3|            let r = _presence_task.await;\n168:7c9|            warn!(\"_presence_task: Chat room closed: {r:#?}\");\n169:b4d|            r\n170:554|        }));\n171:d05|\n172:ec7|        Self {\n173:2e2|            _controller_id: uuid::Uuid::new_v4(),\n174:075|            inner,\n175:395|            presence,\n176:155|            _p: PhantomData,\n177:3f4|            _dispatch_task: Arc::new(_dispatch_task),\n178:7d5|            _presence_task: Arc::new(_presence_task),\n179:3b1|            sender,\n180:41e|            receiver,\n181:b65|            ticket,\n182:fb9|            node_identity,\n183:b18|        }\n184:b18|    }\n185:b18|}\n186:d05|\n187:629|#[async_trait::async_trait]\n188:281|impl<T: IChatRoomType> IChatController<T> for ChatController<T> {\n189:ff9|    fn node_identity(&self) -> NodeIdentity {\n190:be3|        self.node_identity\n191:b18|    }\n192:978|    fn sender(&self) -> ChatSender<T> {\n193:392|        self.sender.clone()\n194:b18|    }\n195:1ff|    async fn receiver(&self) -> ChatReceiver<T> {\n196:2a7|        let new_receiver = {\n197:958|            let m = self.receiver.msg_receiver.write().await;\n198:b67|            // let new_receiver = m.clone();\n199:bc1|            // let m2 = &mut *m;\n200:ff1|            // std::mem::swap(m2, &mut new_receiver);\n201:4f0|            // new_receiver\n202:7c9|            m.clone()\n203:aa9|        };\n204:3bb|        ChatReceiver {\n205:d07|            msg_receiver: Arc::new(RwLock::new(new_receiver)),\n206:155|            _p: PhantomData,\n207:b18|        }\n208:b18|    }\n209:d4b|    async fn shutdown(&self) -> anyhow::Result<()> {\n210:b67|        info!(\"shutting down chat controller\");\n211:8c9|        self.inner.shutdown().await\n212:b18|    }\n213:424|    fn chat_presence(&self) -> ChatPresence<T> {\n214:356|        self.presence.clone()\n215:b18|    }\n216:946|    async fn wait_joined(&self, min_nodes: usize) -> anyhow::Result<()> {\n217:131|        let bootstrap = self.ticket.bootstrap.clone();\n218:fdb|        if bootstrap.is_empty() {\n219:58c|            return Ok(());\n220:b18|        }\n221:cb8|        let own_node_id = *self.node_identity.node_id();\n222:267|        let mut attempts = 0;\n223:f76|        let p = self.chat_presence();\n224:4b3|        loop {\n225:8a2|            // Count distinct nodes present in the room. We always count\n226:bc4|            // ourselves: we are trivially \"in\" the room, but our own presence\n227:3f5|            // entry only appears after the first presence broadcast.\n228:9f2|            let mut nodes = p\n229:99d|                .get_presence_list()\n230:dcc|                .await\n231:3fd|                .0\n232:19e|                .into_iter()\n233:97a|                .map(|p| *p.identity.node_id())\n234:566|                .collect::<std::collections::BTreeSet<_>>();\n235:6c9|            nodes.insert(own_node_id);\n236:259|            info!(\n237:809|                \"wait_until_joined: found {}/{} nodes (room bootstrap: {}), attempts: {}\",\n238:4d9|                nodes.len(),\n239:47b|                min_nodes,\n240:faf|                bootstrap.len(),\n241:92d|                attempts\n242:82c|            );\n243:767|            if nodes.len() >= min_nodes || attempts >= 100 {\n244:81d|                break;\n245:b18|            }\n246:a43|            let _ = n0_future::time::timeout(CONNECT_TIMEOUT / 10, p.notified()).await;\n247:d08|            attempts += 1;\n248:b18|        }\n249:8d4|        Ok(())\n250:b18|    }\n251:b18|}\n252:d05|\n253:193|/// Chat message types for a room type.\n254:323|/// Variants: user message, presence update, or ping/pong response.\n255:842|#[derive(Debug, Clone, PartialEq, serde::Serialize, serde::Deserialize)]\n256:584|pub enum ChatMessage<T: IChatRoomType> {\n257:b88|    Message(T::M),\n258:d89|    Presence(Option<T::P>),\n259:d82|    Pong { ping_sender_ts: DateTime<Utc> },\n260:b18|}\n261:d05|\n262:629|#[async_trait::async_trait]\n263:1fb|pub trait IChatController<T: IChatRoomType>: Send + Sync + 'static + std::fmt::Debug {\n264:3bf|    fn node_identity(&self) -> NodeIdentity;\n265:9ad|    fn sender(&self) -> ChatSender<T>;\n266:6c4|    async fn receiver(&self) -> ChatReceiver<T>;\n267:d87|    async fn shutdown(&self) -> anyhow::Result<()>;\n268:583|    fn chat_presence(&self) -> ChatPresence<T>;\n269:26d|    /// Wait until the room's presence list (self always included) holds at\n270:a65|    /// least `min_nodes` distinct nodes. Use 2 for rooms where another node's\n271:a66|    /// *typed presence* is guaranteed (global chat: us + a bootstrap node;\n272:ca8|    /// server chat: us + the server). Use 1 for rooms bootstrap nodes only\n273:6dd|    /// subscribe to raw, without typed presence (the gameplay room), where\n274:2cf|    /// waiting for anyone else would just spin ~30s.\n275:1af|    async fn wait_joined(&self, min_nodes: usize) -> anyhow::Result<()>;\n276:b18|}\n277:d05|\n278:091|#[derive(Clone, Debug)]\n279:baf|pub struct ChatSender<T: IChatRoomType> {\n280:dd5|    inner: Arc<dyn IChatRoomRaw>,\n281:acc|    message_signer: MessageSigner,\n282:189|    current_presence: Arc<RwLock<Option<T::P>>>,\n283:cf7|    chatroom_presence: ChatPresence<T>,\n284:c14|    _p: PhantomData<T>,\n285:b18|}\n286:d05|\n287:629|#[async_trait::async_trait]\n288:d63|impl<T: IChatRoomType> IChatSender<T> for ChatSender<T> {\n289:565|    async fn broadcast_message(&self, message: T::M) -> anyhow::Result<ReceivedMessage<T>> {\n290:762|        let message2 = ChatMessage::<T>::Message(message.clone());\n291:d5e|        let (bytes, sent_preview) = self.message_signer.sign_and_encode(message2)?;\n292:927|        self.inner.broadcast_message(bytes).await?;\n293:81c|        let sent_preview = ReceivedMessage::<T> {\n294:ffa|            _sender_timestamp: sent_preview._timestamp,\n295:1b4|            _received_timestamp: datetime_now(),\n296:4ae|            _message_id: sent_preview._message_id,\n297:95a|            from: sent_preview.from,\n298:f7c|            message,\n299:aa9|        };\n300:b4c|        Ok(sent_preview)\n301:b18|    }\n302:394|    async fn direct_message(\n303:6ef|        &self,\n304:ee6|        to: NodeIdentity,\n305:e07|        message: T::M,\n306:45a|    ) -> anyhow::Result<ReceivedMessage<T>> {\n307:762|        let message2 = ChatMessage::<T>::Message(message.clone());\n308:d5e|        let (bytes, sent_preview) = self.message_signer.sign_and_encode(message2)?;\n309:981|        self.inner.direct_message(to, bytes).await?;\n310:8d5|        let received_message = ReceivedMessage::<T> {\n311:ffa|            _sender_timestamp: sent_preview._timestamp,\n312:1b4|            _received_timestamp: datetime_now(),\n313:4ae|    