:b18|        }\n81:d86|    });\n82:d05|\n83:aee|    // Main receive loop\n84:5d9|    let recv = controller.receiver().await;\n85:bab|    while let Some(msg) = recv.next_message().await {\n86:46d|        let nickname = msg.from.nickname();\n87:698|        match msg.message {\n88:643|            GlobalChatMessageContent::TextMessage { text } => {\n89:aad|                println!(\"RECV {} {}\", nickname, text);\n90:b18|            }\n91:ea8|            _ => {}\n92:b18|        }\n93:b18|    }\n94:d05|\n95:428|    network.shutdown().await?;\n96:8d4|    Ok(())\n97:b18|}\n98:d05|\n99:fb2|#[cfg(test)]\n100:2c2|mod tests {\n101:e11|    #[test]\n102:02e|    fn network_manager_config_builds_with_gameplay_bootstrap_topic() {\n103:afb|        let config = game_logic::network::network_manager_config();\n104:78f|        assert_eq!(\n105:cb8|            config.bootstrap_topics,\n106:62f|            vec![game_logic::network::GLOBAL_GAMEPLAY_TOPIC_ID.to_string()]\n107:82c|        );\n108:b18|    }\n109:b18|}"}],"details":{"readSeekValue":{"tool":"read","path":"/workspace/crack_demo/chat_cli/src/main.rs","range":{"startLine":1,"endLine":109,"totalLines":109},"warnings":[],"truncation":null,"symbol":null,"map":{"requested":false,"appended":false},"lines":[{"line":1,"hash":"45b","anchor":"1:45b","raw":"//! Interactive CLI for the crack demo global chat network.","display":"//! Interactive CLI for the crack demo global chat network."},{"line":2,"hash":"0bd","anchor":"2:0bd","raw":"//!","display":"//!"},{"line":3,"hash":"f2d","anchor":"3:f2d","raw":"//! Connects via `NetworkManager`, sends stdin lines, and prints received","display":"//! Connects via `NetworkManager`, sends stdin lines, and prints received"},{"line":4,"hash":"ae0","anchor":"4:ae0","raw":"//! messages to stdout.","display":"//! messages to stdout."},{"line":5,"hash":"d05","anchor":"5:d05","raw":"","display":""},{"line":6,"hash":"1e8","anchor":"6:1e8","raw":"use anyhow::Context;","display":"use anyhow::Context;"},{"line":7