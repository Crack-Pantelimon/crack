er();\n45:d28|    sender\n46:ad9|        .set_presence(&GlobalChatPresence {\n47:0b5|            url: \"\".into(),\n48:f6b|            platform: \"chat_cli\".into(),\n49:e2b|            is_server: None,\n50:417|        })\n51:d19|        .await;\n52:d05|\n53:8f1|    controller\n54:805|        .wait_joined(2)\n55:dcc|        .await\n56:c40|        .context(\"Failed wait_joined\")?;\n57:d05|\n58:37f|    println!(\"READY {}\", own_nickname);\n59:d05|\n60:b34|    // Spawn a stdin reader task\n61:da4|    let sender_clone = sender.clone();\n62:849|    tokio::spawn(async move {\n63:197|        let stdin = tokio::io::stdin();\n64:b77|        let mut reader = BufReader::new(stdin).lines();\n65:e9a|        while let Ok(Some(line)) = reader.next_line().await {\n66:4f3|            let trimmed = line.trim();\n67:d98|            if !trimmed.is_empty() {\n68:9b7|                let msg = GlobalChatMessageContent::TextMessage {\n69:085|                    text: trimmed.to_string(),\n70:aa9|                };\n71:f92|                match sender_clone.broadcast_message(msg).await {\n72:d7a|                    Ok(_) => {\n73:d75|                        println!(\"SENT {}\", trimmed);\n74:b18|                    }\n75:ba5|                    Err(e) => {\n76:cf6|                        eprintln!(\"Error sending message: {:?}\", e);\n77:b18|                    }\n78:b18|                }\n79:b18|            }\n80:b18|        }\n81:d86|    });\n82:d05|\n83:aee|    // Main receive loop\n84:5d9|    let recv = controller.receiver().await;\n85:bab|    while let Some(msg) = recv.next_message().await {\n86:46d|        let nickname = msg.from.nickname();\n87:698|        match msg.message {\n88:643|            GlobalChatMessageContent::TextMessage { text } => {\n89:aad|                println!(\"RECV {} {}\", nickname, text);\n90:b18|            }\n91:ea8|            _ => {}\n92:b18|        }\n93:b18|    }\n94:d05|\n95:428|    network.shutdown().await?;\n96:8d4|    Ok(())\n97:b18|}\n98:d05|\n99: