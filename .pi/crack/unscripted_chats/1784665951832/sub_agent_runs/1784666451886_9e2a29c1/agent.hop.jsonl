{"type":"message_end","message":{"role":"toolResult","toolCallId":"tool_ac240f51-3a08-48e5-b146-c3bae7a6d75","toolName":"read","content":[{"type":"text","text":"1:11a|//! Cross-platform asynchronous and time-related utilities for Crack projects.\n2:0bd|//!\n3:ad6|//! The crate presents a small, runtime-neutral surface that works on both\n4:2da|//! native targets and WebAssembly. It re-exports [`n0_future`] so callers can\n5:c64|//! use compatible task and timing primitives without adding a separate\n6:2bb|//! dependency.\n7:d05|\n8:b11|/// Re-exports the asynchronous runtime abstraction used by this crate.\n9:867|pub use n0_future;\n10:d05|\n11:837|/// Returns the current UTC Unix timestamp in milliseconds.\n12:611|///\n13:717|/// The value is measured from the Unix epoch and is suitable for logging,\n14:221|/// elapsed-time calculations, and protocol timestamps. It is not monotonic, so\n15:c91|/// wall-clock adjustments can make successive values move backward.\n16:ccf|pub fn get_timestamp_now_ms() -> i64 {\n17:008|    chrono::offset::Utc::now().timestamp_millis()\n18:b18|}\n19:d05|\n20:d81|/// Spawns a `Send` future on the runtime selected by [`n0_future`].\n21:611|///\n22:29a|/// `f` is scheduled for concurrent execution and may outlive the caller. Its\n23:681|/// output must be `Send` because the runtime is free to run the task on another\n24:479|/// thread. The returned handle can be awaited to retrieve that output.\n25:aa6|pub fn spawn<F>(f: F) -> n0_future::task::JoinHandle<F::Output>\n26:921|where\n27:3be|    F: Future + Send + 'static,\n28:e88|    F::Output: Send + 'static,\n29:1fc|{\n30:059|    n0_future::task::spawn(f)\n31:b18|}\n32:d05|\n33:25e|/// Generates a uniformly distributed pseudorandom `u32`.\n34:611|///\n35:30b|/// The value is obtained from the platform-backed random-number generator\n36:887|/// configured by `rand`, including the WebAssembly-compatible backend on wasm\n37:707|/// targets.\n38:59d|pub fn random_u32() -> u32 {\n39:17f|    ::rand::random()\n40:b18|}\n41:d05|\n42:9b6|/// Suspends the current task for at least `dt_ms` milliseconds.\n43:611|///\n44:5bc|/// `dt_ms` is converted to a [`std::time::Duration`] and scheduled through\n45:712|/// [`n0_future::time::sleep`]. Actual wake-up time can be longer when the\n46:684|/// runtime or platform scheduler is busy.\n47:851|pub async fn sleep_ms(dt_ms: u32) {\n48:47e|    let _sleep = n0_future::time::sleep(std::time::Duration::from_millis(dt_ms as u64)).await;\n49:b18|}\n50:d05|\n51:fb2|#[cfg(test)]\n52:2c2|mod tests {\n53:1e0|    use super::*;\n54:dd1|    #[cfg(target_arch = \"wasm32\")]\n55:0a5|    use wasm_bindgen_test::wasm_bindgen_test as test;\n56:d05|\n57:e11|    #[test]\n58:623|    fn smoke_get_timestamp_now_ms() {\n59:bbc|        let ts = get_timestamp_now_ms();\n60:3bb|        assert!(ts > 0, \"timestamp should be positive, got {ts}\");\n61:b18|    }\n62:d05|\n63:e11|    #[test]\n64:d1f|    fn smoke_random_u32() {\n65:451|        // Two draws should (overwhelmingly) differ; guards against a stubbed RNG.\n66:feb|        assert_ne!(random_u32(), random_u32());\n67:b18|    }\n68:d05|\n69:d8e|    async fn sleep_ms_body() {\n70:f25|        let before = get_timestamp_now_ms();\n71:97c|        sleep_ms(20).await;\n72:84a|        let elapsed = get_timestamp_now_ms() - before;\n73:2e1|        assert!(elapsed >= 15, \"sleep_ms(20) returned after {elapsed}ms\");\n74:b18|    }\n75:d05|\n76:c00|    #[cfg(not(target_arch = \"wasm32\"))]\n77:483|    #[tokio::test]\n78:b73|    async fn smoke_sleep_ms() {\n79:232|        sleep_ms_body().await;\n80:b18|    }\n81:d05|\n82:dd1|    #[cfg(target_arch = \"wasm32\")]\n83:875|    #[wasm_bindgen_test::wasm_bindgen_test]\n84:b73|    async fn smoke_sleep_ms() {\n85:232|        sleep_ms_body().await;\n86:b18|    }\n87:b18|}"}],"details":{"readSeekValue":{"tool":"read","path":"/workspace/rust_pkg/_crack_utils/src/lib.rs","range":{"startLine":1,"endLine":87,"totalLines":87},"warnings":[],"truncation":null,"symbol":null,"map":{"requested":false,"appended":false},"lines":[{"line":1,"hash":"11a","anchor":"1:11a","raw":"//! Cross-platform asynchronous and time-related utilities for Crack projects.","display":"//! Cross-platform asynchronous and time-related utilities for Crack projects."},{"line":2,"hash":"0bd","anchor":"2:0bd","raw":"//!","display":"//!"},{"line":3,"hash":"ad6","anchor":"3:ad6","raw":"//! The crate presents a small, runtime-neutral surface that works on both","display":"//! The crate presents a small, runtime-neutral surface that works on both"},{"line":4,"hash":"2da","anchor":"4:2da","raw":"//! native targets and WebAssembly. It re-exports [`n0_future`] so callers can","display":"//! native targets and WebAssembly. It re-exports [`n0_future`] so callers can"},{"line":5,"hash":"c64","anchor":"5:c64","raw":"//! use compatible task and timing primitives without adding a separate","display":"//! use compatible task and timing primitives without adding a separate"},{"line":6,"hash":"2bb","anchor":"6:2bb","raw":"//! dependency.","display":"//! dependency."},{"line":7,"hash":"d05","anchor":"7:d05","raw":"","display":""},{"line":8,"hash":"b11","anchor":"8:b11","raw":"/// Re-exports the asynchronous runtime abstraction used by this crate.","display":"/// Re-exports the asynchronous runtime abstraction used by this crate."},{"line":9,"hash":"867","anchor":"9:867","raw":"pub use n0_future;","display":"pub use n0_future;"},{"line":10,"hash":"d05","anchor":"10:d05","raw":"","display":""},{"line":11,"hash":"837","anchor":"11:837","raw":"/// Returns the current UTC Unix timestamp in milliseconds.","display":"/// Returns the current UTC Unix timestamp in milliseconds."},{"line":12,"hash":"611","anchor":"12:611","raw":"///","display":"///"},{"line":13,"hash":"717","anchor":"13:717","raw":"/// The value is measured from the Unix epoch and is suitable for logging,","display":"/// The value is measured from the Unix epoch and is suitable for logging,"},{"line":14,"hash":"221","anchor":"