_future::time::sleep(std::time::Duration::from_millis(dt_ms as u64)).await;\n}\n\n#[cfg(test)]\nmod tests {\n    #[cfg(target_arch = \"wasm32\")]\n    use wasm_bindgen_test::wasm_bindgen_test as test;\n    use super::*;\n\n    #[test]\n    fn smoke_get_timestamp_now_ms() {\n        let ts = get_timestamp_now_ms();\n        assert!(ts > 0, \"timestamp should be positive, got {ts}\");\n    }\n\n    #[test]\n    fn smoke_random_u32() {\n        // Two draws should (overwhelmingly) differ; guards against a stubbed RNG.\n        assert_ne!(random_u32(), random_u32());\n    }\n\n    async fn sleep_ms_body() {\n        let before = get_timestamp_now_ms();\n        sleep_ms(20).await;\n        let elapsed = get_timestamp_now_ms() - before;\n        assert!(elapsed >= 15, \"sleep_ms(20) returned after {elapsed}ms\");\n    }\n\n    #[cfg(not(target_arch = \"wasm32\"))]\n    #[tokio::test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n\n    #[cfg(target_arch = \"wasm32\")]\n    #[wasm_bindgen_test::wasm_bindgen_test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n}\nEOF"}}],"api":"openai-completions","provider":"nvidia","model":"nvidia/nemotron-3-ultra-550b-a55b","usage":{"input":3957,"output":1315,"cacheRead":4352,"cacheWrite":0,"reasoning":0,"totalTokens":9624,"cost":{"input":0.0019785,"output":0.0032875,"cacheRead":0.0006527999999999999,"cacheWrite":0,"total":0.0059188}},"stopReason":"toolUse","timestamp":1784616286353,"responseId":"chatcmpl-fa118385-91c0-45d3-bb3a-2b7122082c83"},"toolResults":[{"role":"toolResult","toolCallId":"call-611b0d3f-a169-4b9f-a0d2-aefc2712eafc","toolName":"bash","content":[{"type":"text","text":"(no output)"}],"isError":false,"timestamp":1784616367929}]}
