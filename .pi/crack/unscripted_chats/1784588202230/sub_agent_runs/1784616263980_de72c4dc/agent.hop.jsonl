nvenience wrapper around `n0_future::task::spawn` that\n/// spawns a `Send + 'static` future onto the `n0_future` task executor\n/// and returns a `JoinHandle` for awaiting its result.\n///\n/// # Type Parameters\n///\n/// * `F` - A future type that implements `Future + Send + 'static`\n/// * `F::Output` - The output type of the future, must implement `Send + 'static`\n///\n/// # Arguments\n///\n/// * `f` - The future to spawn\n///\n/// # Returns\n///\n/// A `JoinHandle<F::Output>` that can be awaited to get the future's result.\n///\n/// # Example\n///\n/// ```rust,ignore\n/// let handle = _crack_utils::spawn(async {\n///     // Do some async work\n///     42\n/// });\n/// let result = handle.await;\n/// assert_eq!(result, 42);\n/// ```\npub fn spawn<F>(f: F) -> n0_future::task::JoinHandle<F::Output>\nwhere\n    F: Future + Send + 'static,\n    F::Output: Send + 'static,\n{\n    n0_future::task::spawn(f)\n}\n\n/// Generates a random `u32` using `nanorand`.\n///\n/// Uses `rand::random()` which internally uses `nanorand`'s `WyRand`\n/// for fast, high-quality random number generation.\n///\n/// # Returns\n///\n/// A random `u32` value.\n///\n/// # Example\n///\n/// ```\n/// let a = _crack_utils::random_u32();\n/// let b = _crack_utils::random_u32();\n/// assert_ne!(a, b); // Extremely likely to be different\n/// ```\npub fn random_u32() -> u32 {\n    ::rand::random()\n}\n\n/// Sleeps asynchronously for the specified number of milliseconds.\n///\n/// Uses `n0_future::time::sleep` to yield control for the specified duration.\n/// The sleep duration is converted from milliseconds to a `std::time::Duration`.\n///\n/// # Arguments\n///\n/// * `dt_ms` - Duration to sleep in milliseconds (as `u32`)\n///\n/// # Example\n///\n/// ```rust,ignore\n/// let start = _crack_utils::get_timestamp_now_ms();\n/// _crack_utils::sleep_ms(100).await;\n/// let elapsed = _crack_utils::get_timestamp_now_ms() - start;\n/// assert!(elapsed >= 90); // Allow some slack\n/// ```\npub async fn sleep_ms(dt_ms: u32) {\n    let _sleep = n0_future::time::sleep(std::time::Duration::from_millis(dt_ms as u64)).await;\n}\n\n#[cfg(test)]\nmod tests {\n    #[cfg(target_arch = \"wasm32\")]\n    use wasm_bindgen_test::wasm_bindgen_test as test;\n    use super::*;\n\n    #[test]\n    fn smoke_get_timestamp_now_ms() {\n        let ts = get_timestamp_now_ms();\n        assert!(ts > 0, \"timestamp should be positive, got {ts}\");\n    }\n\n    #[test]\n    fn smoke_random_u32() {\n        // Two draws should (overwhelmingly) differ; guards against a stubbed RNG.\n        assert_ne!(random_u32(), random_u32());\n    }\n\n    async fn sleep_ms_body() {\n        let before = get_timestamp_now_ms();\n        sleep_ms(20).await;\n        let elapsed = get_timestamp_now_ms() - before;\n        assert!(elapsed >= 15, \"sleep_ms(20) returned after {elapsed}ms\");\n    }\n\n    #[cfg(not(target_arch = \"wasm32\"))]\n    #[tokio::test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n\n    #[cfg(target_arch = \"wasm32\")]\n    #[wasm_bindgen_test::wasm_bindgen_test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n}\nEOF"}}],"api":"openai-completions","provider":"nvidia","model":"nvidia/nemotron-3-ultra-550b-a55b","usage":{"input":3064,"output":1334,"cacheRead":8704,"cacheWrite":0,"reasoning":0,"totalTokens":13102,"cost":{"input":0.001532,"output":0.0033350000000000003,"cacheRead":0.0013055999999999999,"cacheWrite":0,"total":0.0061725999999999994}},"stopReason":"toolUse","timestamp":1784616387534,"responseId":"chatcmpl-44e4c1b3-694f-4afa-b07b-29dcb645839c"},{"role":"toolResult","toolCallId":"call-24808a00-3d1c-4a88-93fd-20c3eab2c119","toolName":"bash","content":[{"type":"text","text":"(no output)"}],"isError":false,"timestamp":1784616428606},{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me test the build again.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call-c3ea8666-2223-409b-a1e4-319205