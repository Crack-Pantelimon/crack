_ms(dt_ms: u32) {\n    let _sleep = n0_future::time::sleep(std::time::Duration::from_millis(dt_ms as u64)).await;\n}\n\n#[cfg(test)]\nmod tests {\n    #[cfg(target_arch = \"wasm32\")]\n    use wasm_bindgen_test::wasm_bindgen_test as test;\n    use super::*;\n\n    #[test]\n    fn smoke_get_timestamp_now_ms() {\n        let ts = get_timestamp_now_ms();\n        assert!(ts > 0, \"timestamp should be positive, got {ts}\");\n    }\n\n    #[test]\n    fn smoke_random_u32() {\n        // Two draws should (overwhelmingly) differ; guards against a stubbed RNG.\n        assert_ne!(random_u32(), random_u32());\n    }\n\n    async fn sleep_ms_body() {\n        let before = get_timestamp_now_ms();\n        sleep_ms(20).await;\n        let elapsed = get_timestamp_now_ms() - before;\n        assert!(elapsed >= 15, \"sleep_ms(20) returned after {elapsed}ms\");\n    }\n\n    #[cfg(not(target_arch = \"wasm32\"))]\n    #[tokio::test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n\n    #[cfg(target_arch = \"wasm32\")]\n    #[wasm_bindgen_test::wasm_bindgen_test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n}\nEOF"}}],"api":"openai-completions","provider":"nvidia","model":"nvidia/nemotron-3-ultra-550b-a55b","usage":{"input":3064,"output":1334,"cacheRead":8704,"cacheWrite":0,"reasoning":0,"totalTokens":13102,"cost":{"input":0.001532,"output":0.0033350000000000003,"cacheRead":0.0013055999999999999,"cacheWrite":0,"total":0.0061725999999999994}},"stopReason":"toolUse","timestamp":1784616387534,"responseId":"chatcmpl-44e4c1b3-694f-4afa-b07b-29dcb645839c"},"toolResults":[{"role":"toolResult","toolCallId":"call-24808a00-3d1c-4a88-93fd-20c3eab2c119","toolName":"bash","content":[{"type":"text","text":"(no output)"}],"isError":false,"timestamp":1784616428606}]}
