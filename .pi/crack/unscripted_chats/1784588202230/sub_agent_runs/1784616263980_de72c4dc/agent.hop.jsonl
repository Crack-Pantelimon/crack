tor.\n///\n/// This is a convenience wrapper around `n0_future::task::spawn` that\n/// spawns a `Send + 'static` future onto the `n0_future` task executor\n/// and returns a `JoinHandle` for awaiting its result.\n///\n/// # Type Parameters\n///\n/// * `F` - A future type that implements `Future + Send + 'static`\n/// * `F::Output` - The output type of the future, must implement `Send + 'static`\n///\n/// # Arguments\n///\n/// * `f` - The future to spawn\n///\n/// # Returns\n///\n/// A `JoinHandle<F::Output>` that can be awaited to get the future's result.\n///\n/// # Example\n///\n/// ```rust,ignore\n/// let handle = _crack_utils::spawn(async {\n///     // Do some async work\n///     42\n/// });\n/// let result = handle.await;\n/// assert_eq!(result, 42);\n/// ```\npub fn spawn<F>(f: F) -> n0_future::task::JoinHandle<F::Output>\nwhere\n    F: Future + Send + 'static,\n    F::Output: Send + 'static,\n{\n    n0_future::task::spawn(f)\n}\n\n/// Generates a random `u32` using `nanorand`.\n///\n/// Uses `rand::random()` which internally uses `nanorand`'s `WyRand`\n/// for fast, high-quality random number generation.\n///\n/// # Returns\n///\n/// A random `u32` value.\n///\n/// # Example\n///\n/// ```rust\n/// let a = _crack_utils::random_u32();\n/// let b = _crack_utils::random_u32();\n/// assert_ne!(a, b); // Extremely likely to be different\n/// ```\npub fn random_u32() -> u32 {\n    ::rand::random()\n}\n\n/// Sleeps asynchronously for the specified number of milliseconds.\n///\n/// Uses `n0_future::time::sleep` to yield control for the specified duration.\n/// The sleep duration is converted from milliseconds to a `std::time::Duration`.\n///\n/// # Arguments\n///\n/// * `dt_ms` - Duration to sleep in milliseconds (as `u32`)\n///\n/// # Example\n///\n/// ```rust,ignore\n/// let start = _crack_utils::get_timestamp_now_ms();\n/// _crack_utils::sleep_ms(100).await;\n/// let elapsed = _crack_utils::get_timestamp_now_ms() - start;\n/// assert!(elapsed >= 90); // Allow some 