2();\n/// assert_ne!(a, b); // Extremely likely to be different\n/// ```\npub fn random_u32() -> u32 {\n    ::rand::random()\n}\n\n/// Sleeps asynchronously for the specified number of milliseconds.\n///\n/// Uses `n0_future::time::sleep` to yield control for the specified duration.\n/// The sleep duration is converted from milliseconds to a `std::time::Duration`.\n///\n/// # Arguments\n///\n/// * `dt_ms` - Duration to sleep in milliseconds (as `u32`)\n///\n/// # Example\n///\n/// ```rust,ignore\n/// let start = _crack_utils::get_timestamp_now_ms();\n/// _crack_utils::sleep_ms(100).await;\n/// let elapsed = _crack_utils::get_timestamp_now_ms() - start;\n/// assert!(elapsed >= 90); // Allow some slack\n/// ```\npub async fn sleep_ms(dt_ms: u32) {\n    let _sleep = n0_future::time::sleep(std::time::Duration::from_millis(dt_ms as u64)).await;\n}\n\n#[cfg(test)]\nmod tests {\n    #[cfg(target_arch = \"wasm32\")]\n    use wasm_bindgen_test::wasm_bindgen_test as test;\n    use super::*;\n\n    #[test]\n    fn smoke_get_timestamp_now_ms() {\n        let ts = get_timestamp_now_ms();\n        assert!(ts > 0, \"timestamp should be positive, got {ts}\");\n    }\n\n    #[test]\n    fn smoke_random_u32() {\n        // Two draws should (overwhelmingly) differ; guards against a stubbed RNG.\n        assert_ne!(random_u32(), random_u32());\n    }\n\n    async fn sleep_ms_body() {\n        let before = get_timestamp_now_ms();\n        sleep_ms(20).await;\n        let elapsed = get_timestamp_now_ms() - before;\n        assert!(elapsed >= 15, \"sleep_ms(20) returned after {elapsed}ms\");\n    }\n\n    #[cfg(not(target_arch = \"wasm32\"))]\n    #[tokio::test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n\n    #[cfg(target_arch = \"wasm32\")]\n    #[wasm_bindgen_test::wasm_bindgen_test]\n    async fn smoke_sleep_ms() {\n        sleep_ms_body().await;\n    }\n}\n"}],"isError":false,"timestamp":1784616471667}]}
