+# Per-subprocess timeout guarding the synchronous git materialisation steps that
+# run off the event loop via asyncio.to_thread (see ensure_sandbox). Without it a
+# stuck git would pin a thread of the default executor and re-introduce the
+# freeze at scale.
+_GIT_SUB_TIMEOUT = 60
+# Bounds how many sandboxes can do the git tree materialisation at once. The
+# slow ``git archive | tar -x`` + 4 plumbing commands is the fs/git-pressure
+# hot spot, so we cap overlap here while still letting the ``podman run`` part
+# of other sandboxes overlap freely.
+_SANDBOX_MAT_SEM: asyncio.Semaphore | None = None
+
+
+def _materialise_sem() -> asyncio.Semaphore:
+    global _SANDBOX_MAT_SEM
+    if _SANDBOX_MAT_SEM is None:
+        _SANDBOX_MAT_SEM = asyncio.Semaphore(2)
+    return _SANDBOX_MAT_SEM
 
 
 def sandbox_name(conv_id: str) -> str:
