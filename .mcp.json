{
  "mcpServers": {
    "web-search": {
      "command": "node",
      "args": ["/root/web-search-mcp/dist/index.js"],
      "env": {
        "BROWSER_HEADLESS": "true"
      }
    },
    "chromium": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@1.6.0",
        "--headless",
        "--isolated",
        "--executablePath",
        "/usr/bin/chromium",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-gpu",
        "--no-usage-statistics",
        "--allow-unrestricted-paths"
      ]
    },
    "firefox": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.78",
        "--browser",
        "firefox",
        "--headless",
        "--isolated",
        "--allow-unrestricted-file-access",
        "--output-dir",
        "/workspace/.playwright-mcp"
      ]
    },
    "blender": {
      "command": "/workspace/_docker/_blender_mcp_lazy.sh",
      "env": {
        "BLENDER_HOST": "localhost",
        "BLENDER_PORT": "9876",
        "DISABLE_TELEMETRY": "true"
      }
    },
    "graphiti": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://graphiti-mcp:8000/mcp",
        "--allow-http"
      ],
      "env": {
        "GRAPHITI_TELEMETRY_ENABLED": "false",
        "DO_NOT_TRACK": "1"
      }
    },
    "code-search": {
      "command": "npx",
      "args": ["-y", "@zilliz/claude-context-mcp@0.1.15"],
      "env": {
        "MILVUS_ADDRESS": "milvus-standalone:19530",
        "EMBEDDING_PROVIDER": "Ollama",
        "OLLAMA_HOST": "http://ollama:11434",
        "EMBEDDING_MODEL": "all-minilm",
        "EMBEDDING_DIMENSION": "384",
        "CODEBASE_PATH": "/workspace",
        "CUSTOM_IGNORE_PATTERNS": "target/**,node_modules/**,_slop/**,.playwright-mcp/**,venv/**,**/.venv/**,**/site-packages/**"
      }
    },
    "serena": {
      "command": "/root/.local/bin/serena",
      "args": [
        "start-mcp-server",
        "--context", "claude-code",
        "--project", "/workspace",
        "--transport", "stdio",
        "--enable-web-dashboard", "false",
        "--enable-gui-log-window", "false",
        "--log-level", "ERROR"
      ],
      "env": {
        "HOME": "/root",
        "CARGO_TARGET_DIR": "/workspace/target/serena-lang-tools/rust-anal"
      }
    }
  }
}
